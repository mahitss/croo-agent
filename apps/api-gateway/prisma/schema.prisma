datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  guest
  user
  developer
  admin
}

enum UserStatus {
  active
  suspended
}

enum Visibility {
  public
  private
  unlisted
}

enum AgentStatus {
  active
  inactive
  busy
}

enum VerificationStatus {
  pending
  verified
  rejected
}

enum PricingType {
  per_request
  subscription
  enterprise
  free_tier
}

enum NodeType {
  task
  decision
  parallel
  delay
  merge
  human_approval
  retry
  payment
  verification
  notification
  webhook
  loop
}

enum ExecutionStatus {
  pending
  running
  completed
  failed
}

enum TaskStatus {
  pending
  running
  completed
  failed
}

enum LogLevel {
  info
  warn
  error
  debug
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum NotificationType {
  info
  success
  warning
  error
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  username      String         @unique
  fullName      String?        @map("full_name")
  avatarUrl     String?        @map("avatar_url")
  role          Role           @default(user)
  emailVerified Boolean        @default(false) @map("email_verified")
  status        UserStatus     @default(active)
  lastLoginAt   DateTime?      @map("last_login_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")
  
  wallets       Wallet[]
  sessions      Session[]
  apiKeys       ApiKey[]
  agents        Agent[]
  workflows     Workflow[]
  executions    Execution[]
  reviews       Review[]
  notifications Notification[]
  auditLogs     AuditLog[]

  @@index([email])
  @@index([username])
  @@index([role])
  @@map("users")
}

model Wallet {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  address      String    @unique
  network      String
  balance      Decimal   @db.Decimal(18, 4)
  currency     String    @default("USDC")
  createdAt    DateTime  @default(now()) @map("created_at")
  
  user         User      @relation(fields: [userId], references: [id])
  paymentsSent Payment[] @relation("PayerWallet")
  paymentsRecv Payment[] @relation("PayeeWallet")

  @@index([userId])
  @@index([address])
  @@map("wallets")
}

model Session {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  refreshTokenHash String   @map("refresh_token_hash")
  ipAddress        String?  @map("ip_address")
  userAgent        String?  @map("user_agent")
  expiresAt        DateTime @map("expires_at")
  createdAt        DateTime @default(now()) @map("created_at")

  user             User     @relation(fields: [userId], references: [id])

  @@map("sessions")
}

model ApiKey {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  keyPrefix  String    @map("key_prefix")
  keyHash    String    @map("key_hash")
  name       String
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user       User      @relation(fields: [userId], references: [id])

  @@map("api_keys")
}

model Agent {
  id                 String             @id @default(uuid())
  ownerId            String             @map("owner_id")
  slug               String             @unique
  name               String
  shortDescription   String             @map("short_description")
  longDescription    String             @map("long_description")
  logoUrl            String?            @map("logo_url")
  visibility         Visibility         @default(public)
  status             AgentStatus        @default(active)
  verificationStatus VerificationStatus @default(pending) @map("verification_status")
  averageRating      Decimal            @default(5.0) @db.Decimal(3, 2) @map("average_rating")
  trustScore         Decimal            @default(100.0) @db.Decimal(5, 2) @map("trust_score")
  totalJobs          Int                @default(0) @map("total_jobs")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  owner              User               @relation(fields: [ownerId], references: [id])
  versions           AgentVersion[]
  capabilities       AgentCapability[]
  pricingModels      PricingModel[]
  tasksAssigned      Task[]
  reviews            Review[]

  @@index([ownerId])
  @@index([slug])
  @@index([status])
  @@index([trustScore])
  @@map("agents")
}

model AgentVersion {
  id          String   @id @default(uuid())
  agentId     String   @map("agent_id")
  version     String
  changelog   String?
  sdkVersion  String?  @map("sdk_version")
  endpointUrl String   @map("endpoint_url")
  publishedAt DateTime @default(now()) @map("published_at")

  agent       Agent    @relation(fields: [agentId], references: [id])

  @@map("agent_versions")
}

model Capability {
  id          String            @id @default(uuid())
  name        String            @unique
  description String?
  
  agents      AgentCapability[]

  @@map("capabilities")
}

model AgentCapability {
  agentId      String @map("agent_id")
  capabilityId String @map("capability_id")

  agent      Agent      @relation(fields: [agentId], references: [id])
  capability Capability @relation(fields: [capabilityId], references: [id])

  @@id([agentId, capabilityId])
  @@map("agent_capabilities")
}

model PricingModel {
  id          String      @id @default(uuid())
  agentId     String      @map("agent_id")
  pricingType PricingType @map("pricing_type")
  amount      Decimal     @db.Decimal(18, 4)
  currency    String      @default("USDC")
  createdAt   DateTime    @default(now()) @map("created_at")

  agent       Agent       @relation(fields: [agentId], references: [id])

  @@map("pricing_models")
}

model Workflow {
  id          String         @id @default(uuid())
  ownerId     String         @map("owner_id")
  name        String
  description String?
  visibility  Visibility     @default(public)
  createdAt   DateTime       @default(now()) @map("created_at")

  owner       User           @relation(fields: [ownerId], references: [id])
  nodes       WorkflowNode[]
  edges       WorkflowEdge[]
  executions  Execution[]

  @@map("workflows")
}

model WorkflowNode {
  id            String   @id @default(uuid())
  workflowId    String   @map("workflow_id")
  nodeType      NodeType @map("node_type")
  label         String
  configuration Json     @default("{}")
  positionX     Int      @map("position_x")
  positionY     Int      @map("position_y")

  workflow      Workflow @relation(fields: [workflowId], references: [id])

  @@map("workflow_nodes")
}

model WorkflowEdge {
  id         String   @id @default(uuid())
  workflowId String   @map("workflow_id")
  sourceNode String   @map("source_node")
  targetNode String   @map("target_node")

  workflow   Workflow @relation(fields: [workflowId], references: [id])

  @@map("workflow_edges")
}

model Execution {
  id          String          @id @default(uuid())
  workflowId  String          @map("workflow_id")
  initiatedBy String          @map("initiated_by")
  status      ExecutionStatus @default(pending)
  startedAt   DateTime        @default(now()) @map("started_at")
  completedAt DateTime?       @map("completed_at")
  totalCost   Decimal?        @db.Decimal(18, 4) @map("total_cost")

  workflow    Workflow        @relation(fields: [workflowId], references: [id])
  user        User            @relation(fields: [initiatedBy], references: [id])
  tasks       Task[]
  payments    Payment[]

  @@index([workflowId])
  @@index([status])
  @@map("executions")
}

model Task {
  id              String     @id @default(uuid())
  executionId     String     @map("execution_id")
  assignedAgentId String?    @map("assigned_agent_id")
  taskName        String     @map("task_name")
  status          TaskStatus @default(pending)
  inputPayload    Json       @default("{}") @map("input_payload")
  outputPayload   Json       @default("{}") @map("output_payload")
  retryCount      Int        @default(0) @map("retry_count")
  startedAt       DateTime   @default(now()) @map("started_at")
  completedAt     DateTime?  @map("completed_at")

  execution       Execution  @relation(fields: [executionId], references: [id])
  agent           Agent?     @relation(fields: [assignedAgentId], references: [id])
  logs            TaskLog[]

  @@map("tasks")
}

model TaskLog {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  logLevel  LogLevel @default(info) @map("log_level")
  message   String
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  task      Task     @relation(fields: [taskId], references: [id])

  @@map("task_logs")
}

model Payment {
  id               String        @id @default(uuid())
  payerWalletId    String        @map("payer_wallet_id")
  payeeWalletId    String        @map("payee_wallet_id")
  executionId      String        @map("execution_id")
  amount           Decimal       @db.Decimal(18, 4)
  currency         String        @default("USDC")
  blockchainTxHash String?       @map("blockchain_tx_hash")
  status           PaymentStatus @default(pending)
  createdAt        DateTime      @default(now()) @map("created_at")

  payer            Wallet        @relation("PayerWallet", fields: [payerWalletId], references: [id])
  payee            Wallet        @relation("PayeeWallet", fields: [payeeWalletId], references: [id])
  execution        Execution     @relation(fields: [executionId], references: [id])

  @@index([blockchainTxHash])
  @@index([status])
  @@map("payments")
}

model Review {
  id               String   @id @default(uuid())
  reviewerId       String   @map("reviewer_id")
  agentId          String   @map("agent_id")
  rating           Int
  comment          String?
  verifiedPurchase Boolean  @default(false) @map("verified_purchase")
  createdAt        DateTime @default(now()) @map("created_at")

  reviewer         User     @relation(fields: [reviewerId], references: [id])
  agent            Agent    @relation(fields: [agentId], references: [id])

  @@map("reviews")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  type      NotificationType @default(info)
  title     String
  body      String
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user      User             @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?  @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  ipAddress  String?  @map("ip_address")
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  user       User?    @relation(fields: [actorId], references: [id])

  @@map("audit_logs")
}

model FeatureFlag {
  key               String  @id
  enabled           Boolean @default(false)
  rolloutPercentage Int?    @map("rollout_percentage")
  metadata          Json    @default("{}")

  @@map("feature_flags")
}
